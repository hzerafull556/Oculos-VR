APP_NAME=OculosVR Backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Banco local para desenvolvimento.
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=oculosvr_db

# Exemplo de string para MongoDB Atlas:
# MONGODB_URL=mongodb+srv://usuario:senha@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=oculosvr_db

# Nunca versione a chave real no repositorio.
JWT_SECRET_KEY=change_me_in_local_env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
